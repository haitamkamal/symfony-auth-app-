{% extends 'base.html.twig' %}

{% block title %}Hello AdminController!
{% endblock %}

{% block body %}
	<h1>Bonjour</h1>
	{% if app.user %}
		<div class="mb-3">
			You are logged in as
			{{ app.user.username }},
			<p>
				{% if 'ADMIN' in app.user.roles %}
					ADMIN
				{% else %}
					USER
				{% endif %}
			</p>


			<a href="{{ path('app_logout') }}">Logout</a>
			<a href="{{ path('app_upgrade_role') }}">Upgrade Role</a>


		</div>

	{% else %}
		<p>
			si vous n'avez pas de compte
			<a href="{{path('app_register')}}">inscrez-vous ici</a>
		</p>
		<p>si vous avez déjà un compte,
			<a href="{{path('app_login')}}">connectez-vous ici</a>
		</p>

	{% endif %}


{% endblock %}
